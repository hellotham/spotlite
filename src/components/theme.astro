---

---

<div class='flex justify-end md:flex-1'>
  <div class='pointer-events-auto'>
    <button
      type='button'
      id='theme-toggle-button'
      aria-label='Toggle dark mode'
      aria-expanded='false'
      class='group px-3 py-2 rounded-full bg-sugarSwizzle/90 ring-1 ring-opalGray/20 shadow-md transition backdrop-blur dark:bg-blackBeauty/90 dark:ring-opalGray/20 dark:hover:ring-opalGray/30'
      ><svg
        viewBox='0 0 24 24'
        stroke-width='1.5'
        stroke-linecap='round'
        stroke-linejoin='round'
        aria-hidden='true'
        class='h-6 w-6 transition fill-sugarSwizzle stroke-graniteGray dark:hidden [@media(prefers-color-scheme:dark)]:fill-heavenlyPink group-hover:fill-sugarSwizzle [@media(prefers-color-scheme:dark)]:stroke-morningGlory group-hover:stroke-blackBeauty [@media(prefers-color-scheme:dark)]:group-hover:fill-heavenlyPink [@media(prefers-color-scheme:dark)]:group-hover:stroke-morningGlory'
        ><path
          d='M8 12.25A4.25 4.25 0 0 1 12.25 8v0a4.25 4.25 0 0 1 4.25 4.25v0a4.25 4.25 0 0 1-4.25 4.25v0A4.25 4.25 0 0 1 8 12.25v0Z'
        ></path><path
          d='M12.25 3v1.5M21.5 12.25H20M18.791 18.791l-1.06-1.06M18.791 5.709l-1.06 1.06M12.25 20v1.5M4.5 12.25H3M6.77 6.77 5.709 5.709M6.77 17.73l-1.061 1.061'
          fill='none'></path></svg
      ><svg
        viewBox='0 0 24 24'
        aria-hidden='true'
        class='h-6 w-6 hidden transition fill-blackBeauty stroke-graniteGray dark:block [@media_not_(prefers-color-scheme:dark)]:fill-morningGlory/10 [@media_not_(prefers-color-scheme:dark)]:stroke-morningGlory [@media(prefers-color-scheme:dark)]:group-hover:stroke-opalGray'
        ><path
          d='M17.25 16.22a6.937 6.937 0 0 1-9.47-9.47 7.451 7.451 0 1 0 9.47 9.47ZM12.75 7C17 7 17 2.75 17 2.75S17 7 21.25 7C17 7 17 11.25 17 11.25S17 7 12.75 7Z'
          stroke-width='1.5'
          stroke-linecap='round'
          stroke-linejoin='round'></path></svg
      ></button
    >
  </div>
  <div
    id='theme-menu'
    class='text-base text-blackBeauty font-medium mt-1 px-3 py-1 rounded-md bg-sugarSwizzle/90 max-h-56 w-60 hidden pointer-events-auto ring-1 ring-opalGray/20 shadow-md top-10 absolute z-20 overflow-auto backdrop-blur dark:text-sugarSwizzle dark:bg-blackBeauty/90 dark:ring-opalGray/20'
    tabindex='-1'
    role='listbox'
    aria-labelledby='theme-toggle-button'
  >
    <div
      class='py-2 pl-2 pr-4 cursor-default select-none relative hover:text-morningGlory dark:hover:text-morningGlory'
      id='theme-auto'
      role='option'
      aria-selected='false'
    >
      <div id='theme-auto-div' class='flex items-center'>
        <span class='i-heroicons-star h-6 w-6'></span>
        <span class='ml-1 block truncate'>Auto</span>
      </div>
      <span
        id='theme-auto-check'
        class='text-spearmint pr-4 flex hidden items-center inset-y-0 right-0 absolute'
      >
        <span class='i-heroicons-check h-5 w-5'></span>
        <span class='sr-only'>(selected)</span>
      </span>
    </div>
    <div
      class='py-2 pl-2 pr-4 cursor-default select-none relative hover:text-morningGlory dark:hover:text-morningGlory'
      id='theme-light'
      role='option'
      aria-selected='false'
    >
      <div class='flex items-center'>
        <span class='i-heroicons-sun h-6 w-6'></span>
        <span id='theme-light-span' class='ml-1 block truncate'>Light</span>
      </div>
      <span
        id='theme-light-check'
        class='text-spearmint pr-4 flex hidden items-center inset-y-0 right-0 absolute'
      >
        <span class='i-heroicons-check h-5 w-5'></span>
        <span class='sr-only'>(selected)</span>
      </span>
    </div>
    <div
      class='py-2 pl-2 pr-4 cursor-default select-none relative hover:text-morningGlory dark:hover:text-morningGlory'
      id='theme-dark'
      role='option'
      aria-selected='false'
    >
      <div class='flex items-center'>
        <span class='i-heroicons-moon-solid h-6 w-6'></span>
        <span id='theme-dark-span' class='ml-1 block truncate'>Dark</span>
      </div>
      <span
        id='theme-dark-check'
        class='text-spearmint pr-4 flex hidden items-center inset-y-0 right-0 absolute'
      >
        <span class='i-heroicons-check h-5 w-5'></span>
        <span class='sr-only'>(selected)</span>
      </span>
    </div>
  </div>
</div>

<script>
  const button = document.getElementById('theme-toggle-button')
  const menu = document.getElementById('theme-menu')
  const autoBtn = document.getElementById('theme-auto')
  const lightBtn = document.getElementById('theme-light')
  const darkBtn = document.getElementById('theme-dark')

  const updateUI = () => {
    const theme = localStorage.theme
    const autoCheck = document.getElementById('theme-auto-check')
    const lightCheck = document.getElementById('theme-light-check')
    const darkCheck = document.getElementById('theme-dark-check')
    const autoDiv = document.getElementById('theme-auto-div')
    const lightSpan = document.getElementById('theme-light-span')
    const darkSpan = document.getElementById('theme-dark-span')

    if (autoCheck && lightCheck && darkCheck && autoDiv && lightSpan && darkSpan) {
      autoCheck.classList.toggle('hidden', !!theme)
      lightCheck.classList.toggle('hidden', theme !== 'light')
      darkCheck.classList.toggle('hidden', theme !== 'dark')

      autoBtn?.setAttribute('aria-selected', (!theme).toString())
      lightBtn?.setAttribute('aria-selected', (theme === 'light').toString())
      darkBtn?.setAttribute('aria-selected', (theme === 'dark').toString())

      autoDiv.classList.toggle('font-semibold', !theme)
      autoDiv.classList.toggle('text-morningGlory', !theme)
      autoDiv.classList.toggle('font-normal', !!theme)

      lightSpan.classList.toggle('font-semibold', theme === 'light')
      lightSpan.classList.toggle('text-morningGlory', theme === 'light')
      lightSpan.classList.toggle('font-normal', theme !== 'light')

      darkSpan.classList.toggle('font-semibold', theme === 'dark')
      darkSpan.classList.toggle('text-morningGlory', theme === 'dark')
      darkSpan.classList.toggle('font-normal', theme !== 'dark')
    }
  }

  const updateTheme = () => {
    const theme = localStorage.theme
    if (
      theme === 'dark' ||
      (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)
    ) {
      document.documentElement.classList.add('dark')
    } else {
      document.documentElement.classList.remove('dark')
    }
    updateUI()
  }

  if (button && menu) {
    button.addEventListener('click', () => {
      const isExpanded = button.getAttribute('aria-expanded') === 'true'
      button.setAttribute('aria-expanded', (!isExpanded).toString())
      menu.classList.toggle('hidden')
      updateUI()
    })

    document.addEventListener('click', (event) => {
      const isClickInside =
        button.contains(event.target as Node) || menu.contains(event.target as Node)
      if (!isClickInside && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden')
        button.setAttribute('aria-expanded', 'false')
      }
    })
  }

  autoBtn?.addEventListener('click', () => {
    localStorage.removeItem('theme')
    updateTheme()
    menu?.classList.add('hidden')
    button?.setAttribute('aria-expanded', 'false')
  })

  lightBtn?.addEventListener('click', () => {
    localStorage.theme = 'light'
    updateTheme()
    menu?.classList.add('hidden')
    button?.setAttribute('aria-expanded', 'false')
  })

  darkBtn?.addEventListener('click', () => {
    localStorage.theme = 'dark'
    updateTheme()
    menu?.classList.add('hidden')
    button?.setAttribute('aria-expanded', 'false')
  })

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (!localStorage.theme) {
      updateTheme()
    }
  })

  // Initial UI state
  updateUI()
</script>
