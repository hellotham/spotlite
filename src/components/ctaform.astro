---

<form action='/thank-you' class='p-6 border border-border rounded-2xl dark:border-border/40'>
  <h2 class='text-sm text-morningGlory font-semibold font-serif flex'>
    <svg
      viewBox='0 0 24 24'
      fill='none'
      stroke-width='1.5'
      stroke-linecap='round'
      stroke-linejoin='round'
      aria-hidden='true'
      class='flex-none h-6 w-6'
      ><path
        d='M2.75 7.75a3 3 0 0 1 3-3h12.5a3 3 0 0 1 3 3v8.5a3 3 0 0 1-3 3H5.75a3 3 0 0 1-3-3v-8.5Z'
        class='fill-barelyPink stroke-graniteGray dark:fill-barelyPink/10 dark:stroke-opalGray'
      ></path><path
        d='m4 6 6.024 5.479a2.915 2.915 0 0 0 3.952 0L20 6'
        class='stroke-graniteGray dark:stroke-opalGray'></path></svg
    ><span class='ml-3'>Stay up to date</span>
  </h2><p class='text-sm text-graniteGray mt-2 dark:text-opalGray'>
    Get notified when I publish something new, and unsubscribe at any time.
  </p><div class='mt-6 flex'>
    <input
      type='email'
      placeholder='Email address'
      aria-label='Email address'
      required=''
      class='px-3 py-2 appearance-none border border-border/10 rounded-md bg-sugarSwizzle flex-auto min-w-0 shadow-md sm:text-sm dark:text-sugarSwizzle placeholder:text-graniteGray focus:outline-none dark:border-border/30 focus:border-morningGlory dark:bg-blackBeauty/[0.15] focus:ring-4 focus:ring-morningGlory/10 dark:placeholder:text-opalGray dark:focus:border-morningGlory dark:focus:ring-morningGlory/10'
    /><button
      class='text-sm text-sugarSwizzle font-semibold ml-4 px-3 py-2 outline-offset-2 rounded-md bg-blackBeauty inline-flex flex-none gap-2 transition items-center justify-center active:text-sugarSwizzle/70 active:bg-blackBeauty dark:bg-grapeade hover:bg-grapeade active:transition-none dark:active:text-sugarSwizzle/70 dark:active:bg-grapeade dark:hover:bg-grapeade/80'
      type='submit'>Join</button
    >
  </div>
</form>
