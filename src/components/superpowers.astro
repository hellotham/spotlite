---
import D3superpowers from '../components/d3superpowers.astro'
import D3BubbleChart from '../components/d3bubblechart.astro'
import superpowers from '../superpowers.json'

const sortedSuperpowers = [...superpowers].sort((a, b) => a.title.localeCompare(b.title))
---

<div class='p-6 card rounded-2xl'>
  <h2 class='text-lg text-accent font-semibold font-serif flex items-center'>
    <span class='i-heroicons-bolt text-secondary h-6 w-6' aria-hidden='true'></span>
    <span class='ml-3'>Superpowers</span>
  </h2>
  <D3BubbleChart />
  <D3superpowers />
  <ol class='mt-6 space-y-4'>
    {
      sortedSuperpowers.map((item) => (
        <li>
          <button
            type='button'
            class='superpower-trigger group p-2 text-left rounded-xl flex gap-4 w-full transition -m-2 hover:bg-heavenlyPink/50 focus-ring dark:hover:bg-grapeade/30'
            data-title={item.title}
            data-description={item.description}
            data-level={item.level}
            data-comment={item.comment}
          >
            <div class='mt-1 rounded-full flex flex-none h-10 w-10 ring-1 ring-opalGray/20 shadow-md items-center justify-center relative dark:border dark:border-border/50 dark:bg-blackBeauty dark:ring-0'>
              <span class='i-heroicons-bolt text-secondary h-6 w-6 transition group-hover:text-accent' />
            </div>
            <dl class='flex flex-auto flex-wrap gap-x-2'>
              <dt class='sr-only'>Title</dt>
              <dd class='text-sm text-primary font-medium flex-none w-full transition group-hover:text-accent'>
                {item.title}
              </dd>
              <dt class='sr-only'>Level</dt>
              <dd class='text-xs text-secondary'>Level {item.level}</dd>
              <dt class='sr-only'>Comment</dt>
              <dd class='text-xs text-secondary ml-auto opacity-80 italic'>{item.comment}</dd>
            </dl>
          </button>
        </li>
      ))
    }
  </ol>
</div>

<dialog
  id='superpowers-modal'
  class='p-0 border border-primary/30 rounded-2xl bg-sugarSwizzle/95 glass flex-col max-w-lg w-[calc(100%-2rem)] shadow-2xl backdrop-blur-md dark:bg-blackBeauty/90 open:flex'
>
  <div class='p-6 sm:p-8'>
    <div class='mb-6 flex items-start justify-between'>
      <div class='flex gap-3 items-center'>
        <div
          class='rounded-full flex h-12 w-12 ring-1 ring-opalGray/20 shadow-md items-center justify-center dark:border dark:border-border/50 dark:bg-blackBeauty dark:ring-0'
        >
          <span class='i-heroicons-bolt text-accent h-7 w-7'></span>
        </div>
        <h2 id='modal-title' class='text-2xl text-accent leading-none font-bold font-serif'>
          Superpower
        </h2>
      </div>
      <button
        id='close-modal'
        type='button'
        class='text-secondary p-1 rounded-lg transition hover:text-accent focus-ring'
        aria-label='Close modal'
      >
        <span class='i-heroicons-x-mark h-6 w-6'></span>
      </button>
    </div>

    <div class='space-y-6'>
      <div>
        <h3 class='text-xs text-secondary tracking-widest font-bold mb-2 uppercase'>Description</h3>
        <p id='modal-description' class='text-primary leading-relaxed'></p>
      </div>

      <div class='pt-6 border-t border-primary/10 flex flex-wrap gap-6'>
        <div class='flex-1'>
          <h3 class='text-xs text-secondary tracking-widest font-bold mb-1 uppercase'>
            Proficiency
          </h3>
          <p class='text-lg text-accent font-bold'>Level <span id='modal-level'></span></p>
        </div>
        <div id='modal-comment-container' class='flex-[2]'>
          <h3 class='text-xs text-secondary tracking-widest font-bold mb-1 uppercase'>Comment</h3>
          <p id='modal-comment' class='text-sm text-primary italic'></p>
        </div>
      </div>
    </div>
  </div>
</dialog>

<script>
  const setupModal = () => {
    const modal = document.getElementById('superpowers-modal') as HTMLDialogElement
    const triggers = document.querySelectorAll('.superpower-trigger')
    const closeBtn = document.getElementById('close-modal')

    const titleEl = document.getElementById('modal-title')
    const descEl = document.getElementById('modal-description')
    const levelEl = document.getElementById('modal-level')
    const commentEl = document.getElementById('modal-comment')
    const commentContainer = document.getElementById('modal-comment-container')

    if (!modal || !closeBtn) return

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const btn = trigger as HTMLButtonElement
        const { title, description, level, comment } = btn.dataset

        if (titleEl) titleEl.textContent = title || ''
        if (descEl) descEl.textContent = description || ''
        if (levelEl) levelEl.textContent = level || ''

        if (commentEl && commentContainer) {
          if (comment) {
            commentEl.textContent = comment
            commentContainer.classList.remove('hidden')
          } else {
            commentContainer.classList.add('hidden')
          }
        }

        modal.showModal()
        document.body.style.overflow = 'hidden'
      })
    })

    closeBtn.addEventListener('click', () => {
      modal.close()
    })

    modal.addEventListener('click', (e) => {
      const rect = modal.getBoundingClientRect()
      const isInDialog =
        rect.top <= e.clientY &&
        e.clientY <= rect.top + rect.height &&
        rect.left <= e.clientX &&
        e.clientX <= rect.left + rect.width
      if (!isInDialog) {
        modal.close()
      }
    })

    modal.addEventListener('close', () => {
      document.body.style.overflow = ''
    })
  }

  setupModal()
  document.addEventListener('astro:page-load', setupModal)
</script>

<style>
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  /* Fade in animation for dialog */
  dialog[open] {
    animation: fade-in 0.3s ease-out;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
</style>
