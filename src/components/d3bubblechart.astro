---
import superpowers from '../superpowers.json'
---

<div
  id='bubblechart-container'
  class='text-secondary min-h-[400px] w-full relative'
  data-superpowers={JSON.stringify(superpowers)}
>
</div>
<div
  id='bubblechart-tooltip'
  class='text-sm p-4 border border-primary/30 rounded-lg bg-sugarSwizzle/90 glass max-w-xs min-w-[200px] hidden pointer-events-none shadow-xl fixed z-50 backdrop-blur-md dark:bg-blackBeauty/80'
>
</div>

<script>
  import * as d3 from 'd3'

  interface Superpower {
    title: string
    description: string
    level: number
    comment?: string
    code?: string
  }

  interface SuperpowerNode extends Superpower {
    radius: number
    x: number
    y: number
    vx: number
    vy: number
  }

  const setupBubbleChart = () => {
    const container = document.getElementById('bubblechart-container')
    const tooltip = d3.select('#bubblechart-tooltip')

    if (!container || container.dataset.initialized === 'true') return

    const rawData: Superpower[] = JSON.parse(container.getAttribute('data-superpowers') || '[]')
    // Shuffle data for randomized placement
    const data = [...rawData].sort(() => Math.random() - 0.5)

    let animationRunning = false
    let animationFrameId: number | null = null

    const renderChart = () => {
      const chartContainer = document.getElementById('bubblechart-container')
      if (!chartContainer) return

      // Stop any previous animation loop before re-rendering
      animationRunning = false
      if (animationFrameId !== null) {
        cancelAnimationFrame(animationFrameId)
        animationFrameId = null
      }

      // Clear previous content
      chartContainer.innerHTML = ''

      // Dimensions - height proportional to width for responsive layout
      const width = chartContainer.clientWidth
      const height = Math.max(380, Math.min(Math.round(width * 0.6), 620))

      const svg = d3
        .select('#bubblechart-container')
        .append('svg')
        .attr('width', width)
        .attr('height', height)
        .attr('viewBox', [0, 0, width, height])
        .attr('style', 'max-width: 100%; height: auto;')
        .attr('text-anchor', 'middle')

      // Color Scale - Level 1 (Red) to 6 (Green) using Rosely Palette
      const colorScale = d3
        .scaleLinear<string>()
        .domain([1, 2, 3, 4, 5, 6])
        .range(['#d2386c', '#DD4124', '#eada4f', '#3CADD4', '#64bfa4', '#b565a7'])
        .interpolate(d3.interpolateHcl)

      // Compute base radius from available area so bubbles fit without crowding.
      // Target ~30% fill factor: enough room for free Brownian motion.
      const fillFactor = 0.3
      const baseRadius = Math.sqrt((fillFactor * width * height) / (Math.PI * data.length))

      // Level scale: proportional size factor across the observed level range
      const levelMin = Math.min(...data.map((d) => d.level))
      const levelMax = Math.max(...data.map((d) => d.level))
      const levelScale = d3.scaleLinear().domain([levelMin, levelMax]).range([0.7, 1.3])

      // Nodes - initial positions clamped inside bounds to avoid wall-overlap conflicts
      const nodes: SuperpowerNode[] = data.map((d) => {
        const levelFactor = levelScale(d.level)
        const jitter = 0.88 + Math.random() * 0.24 // ±12% random size variation per bubble
        const radius = baseRadius * levelFactor * jitter
        return {
          ...d,
          radius,
          x: radius + Math.random() * (width - radius * 2),
          y: radius + Math.random() * (height - radius * 2),
          vx: 0,
          vy: 0
        }
      })

      // Physics constants
      const brownianStrength = 0.04
      const velocityDecay = 0.985
      const minSpeed = 0.06
      const collisionElasticity = 0.85
      const wallBounce = 0.88
      const maxSpeed = 0.35
      const GAP = 2 // minimum gap between bubble edges

      // Separation-only pass: push overlapping bubbles apart (no velocity change)
      const resolveOverlaps = (passes: number) => {
        for (let pass = 0; pass < passes; pass++) {
          for (let i = 0; i < nodes.length; i++) {
            const a = nodes[i]
            for (let j = i + 1; j < nodes.length; j++) {
              const b = nodes[j]
              const dx = b.x - a.x
              const dy = b.y - a.y
              const distSq = dx * dx + dy * dy
              const minDist = a.radius + b.radius + GAP
              if (distSq < minDist * minDist) {
                const dist = Math.sqrt(distSq) || 0.01
                const push = (minDist - dist) * 0.5
                const nx = dx / dist
                const ny = dy / dist
                a.x -= nx * push
                a.y -= ny * push
                b.x += nx * push
                b.y += ny * push
              }
            }
            // Wall clamp after each bubble's correction
            a.x = Math.max(a.radius, Math.min(width - a.radius, a.x))
            a.y = Math.max(a.radius, Math.min(height - a.radius, a.y))
          }
        }
      }

      // Warm-up: resolve initial overlaps before animation starts
      resolveOverlaps(60)

      // Give each bubble a random initial velocity
      nodes.forEach((d) => {
        const angle = Math.random() * 2 * Math.PI
        d.vx = Math.cos(angle) * minSpeed * (1 + Math.random() * 0.5)
        d.vy = Math.sin(angle) * minSpeed * (1 + Math.random() * 0.5)
      })

      // Phased animation loop - each phase completes for ALL bubbles before the next starts
      const animate = () => {
        if (!animationRunning) return

        // Phase 1: Brownian impulse + friction + integrate position (all bubbles)
        nodes.forEach((d) => {
          d.vx += (Math.random() - 0.5) * brownianStrength
          d.vy += (Math.random() - 0.5) * brownianStrength
          d.vx *= velocityDecay
          d.vy *= velocityDecay
          d.x += d.vx
          d.y += d.vy
        })

        // Phase 2: Resolve positional overlaps (3 passes for cascading cases)
        resolveOverlaps(3)

        // Phase 3: Elastic velocity exchange for touching pairs (after positions settled)
        for (let i = 0; i < nodes.length; i++) {
          const a = nodes[i]
          for (let j = i + 1; j < nodes.length; j++) {
            const b = nodes[j]
            const dx = b.x - a.x
            const dy = b.y - a.y
            const distSq = dx * dx + dy * dy
            const minDist = a.radius + b.radius + GAP
            if (distSq < minDist * minDist) {
              const dist = Math.sqrt(distSq) || 0.01
              const nx = dx / dist
              const ny = dy / dist
              // Normal velocity components (positive = moving toward other)
              const v1n = a.vx * nx + a.vy * ny
              const v2n = b.vx * nx + b.vy * ny
              // Only exchange if a is gaining on b along the collision axis
              if (v1n > v2n) {
                const delta = (v1n - v2n) * collisionElasticity
                a.vx -= delta * nx
                a.vy -= delta * ny
                b.vx += delta * nx
                b.vy += delta * ny
              }
            }
          }
        }

        // Phase 4: Wall bounce - only flip if velocity is pointing INTO the wall
        nodes.forEach((d) => {
          if (d.x - d.radius < 0) {
            d.x = d.radius
            if (d.vx < 0) d.vx = -d.vx * wallBounce
          } else if (d.x + d.radius > width) {
            d.x = width - d.radius
            if (d.vx > 0) d.vx = -d.vx * wallBounce
          }
          if (d.y - d.radius < 0) {
            d.y = d.radius
            if (d.vy < 0) d.vy = -d.vy * wallBounce
          } else if (d.y + d.radius > height) {
            d.y = height - d.radius
            if (d.vy > 0) d.vy = -d.vy * wallBounce
          }
        })

        // Phase 5: Speed bounds - applied last so no other phase can undo them
        nodes.forEach((d) => {
          const speed = Math.sqrt(d.vx * d.vx + d.vy * d.vy)
          if (speed > maxSpeed) {
            d.vx *= maxSpeed / speed
            d.vy *= maxSpeed / speed
          } else if (speed < minSpeed) {
            const s = speed > 0.001 ? speed : 0.001
            d.vx *= minSpeed / s
            d.vy *= minSpeed / s
          }
        })

        node.attr('transform', (d) => `translate(${d.x},${d.y})`)
        animationFrameId = requestAnimationFrame(animate)
      }

      // Place nodes
      const node = svg.append('g').selectAll('g').data(nodes).join('g').attr('class', 'bubble')

      node
        .append('circle')
        .attr('r', (d) => d.radius)
        .attr('fill', (d) => colorScale(d.level))
        .attr('class', 'cursor-pointer transition-opacity duration-200 hover:opacity-80')
        .on('mouseover', function (_event: MouseEvent, d) {
          const item = d
          tooltip.classed('hidden', false)
          tooltip.html(`
          <div class="flex flex-col gap-1">
            <h3 class="font-bold text-accent text-base">${item.title}</h3>
            <p class="text-primary leading-tight">${item.description}</p>
            <div class="mt-2 pt-2 border-t border-primary/20 flex justify-between items-center">
              <span class="text-xs text-secondary uppercase tracking-wider">Proficiency</span>
              <span class="font-bold text-accent">Level ${item.level}</span>
            </div>
            ${item.comment ? `<p class="text-xs italic text-secondary mt-1">"${item.comment}"</p>` : ''}
          </div>
        `)
        })
        .on('mousemove', function (event: MouseEvent) {
          const x = event.clientX
          const y = event.clientY
          const tooltipNode = tooltip.node() as HTMLElement
          const offset = 20

          let left = x + offset
          let top = y + offset

          if (tooltipNode) {
            const rect = tooltipNode.getBoundingClientRect()
            if (left + rect.width > window.innerWidth) {
              left = x - rect.width - offset
            }
            if (top + rect.height > window.innerHeight) {
              top = y - rect.height - offset
            }
          }

          tooltip.style('left', `${left}px`).style('top', `${top}px`)
        })
        .on('mouseout', function () {
          tooltip.classed('hidden', true)
        })
        .on('click', function (_event: MouseEvent, d) {
          const item = d
          const modal = document.getElementById('superpowers-modal') as HTMLDialogElement
          if (!modal) return

          const titleEl = document.getElementById('modal-title')
          const descEl = document.getElementById('modal-description')
          const levelEl = document.getElementById('modal-level')
          const commentEl = document.getElementById('modal-comment')
          const commentContainer = document.getElementById('modal-comment-container')

          if (titleEl) titleEl.textContent = item.title || ''
          if (descEl) descEl.textContent = item.description || ''
          if (levelEl) levelEl.textContent = item.level.toString() || ''

          if (commentEl && commentContainer) {
            if (item.comment) {
              commentEl.textContent = item.comment
              commentContainer.classList.remove('hidden')
            } else {
              commentContainer.classList.add('hidden')
            }
          }

          modal.showModal()
          document.body.style.overflow = 'hidden'
        })

      // Text wrapping logic based on guide
      const text = node
        .append('text')
        .style('font-size', (d) => Math.max(7, Math.min(d.radius * 0.35, 14)) + 'px')
        .style('font-weight', 'bold')
        .style('fill', 'white')
        .style('pointer-events', 'none')

      text
        .selectAll('tspan')
        .data((d) => {
          const name = d.title
          // Split by spaces or hyphens, preserving the hyphen
          return name.split(/[\s-]/g).map((word: string, i: number, arr: string[]) => {
            if (name.includes(`${word}-`) && i < arr.length - 1) return `${word}-`
            return word
          })
        })
        .join('tspan')
        .attr('x', 0)
        .attr('y', (_d, i, nodes) => `${i - nodes.length / 2 + 0.8}em`)
        .text((d) => d)

      // Performance Optimization: Pause animation when off-screen
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !animationRunning) {
              animationRunning = true
              animate()
            } else if (!entry.isIntersecting) {
              animationRunning = false
            }
          })
        },
        { threshold: 0.1 }
      )

      observer.observe(chartContainer)

      // Start animation
      animationRunning = true
      animate()
    }

    renderChart()

    // Resize listener with debouncing or simple re-render
    window.addEventListener('resize', renderChart)

    container.dataset.initialized = 'true'
  }

  // Initialize on page load
  setupBubbleChart()
  document.addEventListener('astro:page-load', setupBubbleChart)
</script>

<style>
  #bubblechart-container svg {
    max-width: 100%;
    height: auto;
  }
</style>
