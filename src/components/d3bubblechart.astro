---
import superpowers from '../superpowers.json'
---

<div
  id='bubblechart-container'
  class='text-secondary min-h-[400px] w-full relative'
  data-superpowers={JSON.stringify(superpowers)}
>
</div>
<div
  id='bubblechart-tooltip'
  class='text-sm p-4 border border-primary/30 rounded-lg bg-sugarSwizzle/90 glass max-w-xs min-w-[200px] hidden pointer-events-none shadow-xl fixed z-50 backdrop-blur-md dark:bg-blackBeauty/80'
>
</div>

<script>
  import * as d3 from 'd3'

  interface Superpower {
    title: string
    description: string
    level: number
    comment?: string
    code?: string
  }

  const setupBubbleChart = () => {
    const container = document.getElementById('bubblechart-container')
    const tooltip = d3.select('#bubblechart-tooltip')

    if (!container || container.dataset.initialized === 'true') return

    const rawData: Superpower[] = JSON.parse(container.getAttribute('data-superpowers') || '[]')
    // Shuffle data for randomized placement
    const data = [...rawData].sort(() => Math.random() - 0.5)

    let animationRunning = false
    let animationFrameId: number | null = null

    const renderChart = () => {
      const chartContainer = document.getElementById('bubblechart-container')
      if (!chartContainer) return

      // Stop any previous animation loop before re-rendering
      animationRunning = false
      if (animationFrameId !== null) {
        cancelAnimationFrame(animationFrameId)
        animationFrameId = null
      }

      // Clear previous content
      chartContainer.innerHTML = ''

      // Dimensions
      const width = chartContainer.clientWidth
      const height = 500
      const margin = 1

      const svg = d3
        .select('#bubblechart-container')
        .append('svg')
        .attr('width', width)
        .attr('height', height)
        .attr('viewBox', [0, 0, width, height])
        .attr('style', 'max-width: 100%; height: auto;')
        .attr('text-anchor', 'middle')

      // Color Scale - Level 1 (Red) to 6 (Green) using Rosely Palette
      const colorScale = d3
        .scaleLinear<string>()
        .domain([1, 2, 3, 4, 5, 6])
        .range(['#d2386c', '#DD4124', '#eada4f', '#3CADD4', '#64bfa4', '#b565a7'])
        .interpolate(d3.interpolateHcl)

      // Radius scale - even smaller bubbles for maximum whitespace and freer movement
      const radiusScale = d3.scaleLinear()
        .domain([1, 6])
        .range([25, 50])

      // Nodes for simulation
      const nodes: any[] = data.map(d => ({
        ...d,
        radius: radiusScale(d.level),
        x: Math.random() * width,
        y: Math.random() * height,
        vx: 0,
        vy: 0
      }))

      // Brownian motion parameters
      const brownianStrength = 0.04 // Random impulse per frame
      const velocityDecay = 0.985 // Gentle friction - preserves momentum longer
      const minSpeed = 0.06 // Speed floor - bubbles never stop
      const minDistance = 0.5 // Minimum spacing between bubble edges
      const collisionElasticity = 0.85 // Energy retention in collision
      const maxSpeed = 0.35 // Maximum velocity magnitude

      // Give each bubble a random initial velocity so they start moving immediately
      nodes.forEach(d => {
        const angle = Math.random() * 2 * Math.PI
        d.vx = Math.cos(angle) * minSpeed * (1 + Math.random())
        d.vy = Math.sin(angle) * minSpeed * (1 + Math.random())
      })

      // Manual animation loop instead of d3 forces
      const animate = () => {
        if (!animationRunning) return

        nodes.forEach((d, i) => {
          // Apply continuous Brownian motion (random walk)
          // Small random impulses each frame for natural motion
          d.vx += (Math.random() - 0.5) * brownianStrength
          d.vy += (Math.random() - 0.5) * brownianStrength

          // Apply friction/damping
          d.vx *= velocityDecay
          d.vy *= velocityDecay

          // Update position
          d.x += d.vx
          d.y += d.vy

          // Elastic bubble-to-bubble collision detection and response
          for (let j = i + 1; j < nodes.length; j++) {
            const other = nodes[j]
            const dx = other.x - d.x
            const dy = other.y - d.y
            const distSq = dx * dx + dy * dy
            const minDistSq = (d.radius + other.radius + minDistance) ** 2

            if (distSq < minDistSq) {
              const dist = Math.sqrt(distSq)
              const overlap = d.radius + other.radius + minDistance - dist

              // Collision normal (normalized direction)
              const nx = dx / dist
              const ny = dy / dist

              // Push bubbles apart to prevent overlap
              const pushDistance = overlap / 2 + 0.001
              d.x -= nx * pushDistance
              d.y -= ny * pushDistance
              other.x += nx * pushDistance
              other.y += ny * pushDistance

              // Elastic collision response: exchange velocity components along collision normal
              // Relative velocity
              const dvx = other.vx - d.vx
              const dvy = other.vy - d.vy
              const dvDotN = dvx * nx + dvy * ny

              // Only collide if bubbles are moving towards each other
              if (dvDotN < 0) {
                // For equal-mass elastic collision, swap normal components
                const impulse = -dvDotN * collisionElasticity

                d.vx += impulse * nx
                d.vy += impulse * ny
                other.vx -= impulse * nx
                other.vy -= impulse * ny
              }
            }
          }

          // Bounding box wall collisions with elastic reflection
          const bounce = 0.92 // Coefficient of restitution
          if (d.x - d.radius < 0) {
            d.x = d.radius
            d.vx = Math.abs(d.vx) * bounce
          } else if (d.x + d.radius > width) {
            d.x = width - d.radius
            d.vx = -Math.abs(d.vx) * bounce
          }

          if (d.y - d.radius < 0) {
            d.y = d.radius
            d.vy = Math.abs(d.vy) * bounce
          } else if (d.y + d.radius > height) {
            d.y = height - d.radius
            d.vy = -Math.abs(d.vy) * bounce
          }

          // Enforce speed bounds: never too fast, never stationary
          const speed = Math.sqrt(d.vx * d.vx + d.vy * d.vy)
          if (speed > maxSpeed) {
            d.vx *= maxSpeed / speed
            d.vy *= maxSpeed / speed
          } else if (speed < minSpeed) {
            // Bubble has stalled - restore to minimum speed in current direction
            // If completely stopped, pick a random direction
            const s = speed > 0 ? speed : 1
            d.vx = (d.vx / s) * minSpeed
            d.vy = (d.vy / s) * minSpeed
            if (speed === 0) {
              const angle = Math.random() * 2 * Math.PI
              d.vx = Math.cos(angle) * minSpeed
              d.vy = Math.sin(angle) * minSpeed
            }
          }
        })

        node.attr('transform', (d: any) => `translate(${d.x},${d.y})`)
        animationFrameId = requestAnimationFrame(animate)
      }

      // Place nodes
      const node = svg.append('g')
        .selectAll('g')
        .data(nodes)
        .join('g')
        .attr('class', 'bubble')

      node
        .append('circle')
        .attr('r', (d: any) => d.radius)
        .attr('fill', (d: any) => colorScale(d.level))
        .attr('class', 'cursor-pointer transition-opacity duration-200 hover:opacity-80')
        .on('mouseover', function (event: MouseEvent, d: any) {
          const item = d
          tooltip.classed('hidden', false)
          tooltip.html(`
          <div class="flex flex-col gap-1">
            <h3 class="font-bold text-accent text-base">${item.title}</h3>
            <p class="text-primary leading-tight">${item.description}</p>
            <div class="mt-2 pt-2 border-t border-primary/20 flex justify-between items-center">
              <span class="text-xs text-secondary uppercase tracking-wider">Proficiency</span>
              <span class="font-bold text-accent">Level ${item.level}</span>
            </div>
            ${item.comment ? `<p class="text-xs italic text-secondary mt-1">"${item.comment}"</p>` : ''}
          </div>
        `)
        })
        .on('mousemove', function (event: MouseEvent) {
          const x = event.clientX
          const y = event.clientY
          const tooltipNode = tooltip.node() as HTMLElement
          const offset = 20

          let left = x + offset
          let top = y + offset

          if (tooltipNode) {
            const rect = tooltipNode.getBoundingClientRect()
            if (left + rect.width > window.innerWidth) {
              left = x - rect.width - offset
            }
            if (top + rect.height > window.innerHeight) {
              top = y - rect.height - offset
            }
          }

          tooltip.style('left', `${left}px`).style('top', `${top}px`)
        })
        .on('mouseout', function () {
          tooltip.classed('hidden', true)
        })
        .on('click', function (event: MouseEvent, d: any) {
          const item = d
          const modal = document.getElementById('superpowers-modal') as HTMLDialogElement
          if (!modal) return

          const titleEl = document.getElementById('modal-title')
          const descEl = document.getElementById('modal-description')
          const levelEl = document.getElementById('modal-level')
          const commentEl = document.getElementById('modal-comment')
          const commentContainer = document.getElementById('modal-comment-container')

          if (titleEl) titleEl.textContent = item.title || ''
          if (descEl) descEl.textContent = item.description || ''
          if (levelEl) levelEl.textContent = item.level.toString() || ''

          if (commentEl && commentContainer) {
            if (item.comment) {
              commentEl.textContent = item.comment
              commentContainer.classList.remove('hidden')
            } else {
              commentContainer.classList.add('hidden')
            }
          }

          modal.showModal()
          document.body.style.overflow = 'hidden'
        })

      // Text wrapping logic based on guide
      const text = node
        .append('text')
        .style('font-size', (d: any) => Math.max(8, Math.min(d.radius / 2.8, 11)) + 'px')
        .style('font-weight', 'bold')
        .style('fill', 'white')
        .style('pointer-events', 'none')

      text
        .selectAll('tspan')
        .data((d: any) => {
          const name = d.title
          // Split by spaces or hyphens, preserving the hyphen
          return name.split(/[\s-]/g).map((word: string, i: number, arr: string[]) => {
            if (name.includes(`${word}-`) && i < arr.length - 1) return `${word}-`
            return word
          })
        })
        .join('tspan')
        .attr('x', 0)
        .attr('y', (d, i, nodes) => `${i - nodes.length / 2 + 0.8}em`)
        .text((d: any) => d)

      // Performance Optimization: Pause animation when off-screen
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !animationRunning) {
            animationRunning = true
            animate()
          } else if (!entry.isIntersecting) {
            animationRunning = false
          }
        })
      }, { threshold: 0.1 })

      observer.observe(chartContainer)

      // Start animation
      animationRunning = true
      animate()
    }

    renderChart()

    // Resize listener with debouncing or simple re-render
    window.addEventListener('resize', renderChart)

    container.dataset.initialized = 'true'
  }

  // Initialize on page load
  setupBubbleChart()
  document.addEventListener('astro:page-load', setupBubbleChart)
</script>

<style>
  #bubblechart-container svg {
    max-width: 100%;
    height: auto;
  }
</style>
