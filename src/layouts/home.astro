---
import Layout from '../layouts/layout.astro'
import { Image } from 'astro:assets'
import Avatar from '../assets/me/avatar.jpg'
import { getCollection } from 'astro:content'
import ImageCards from '../components/imagecards.astro'
import ArticleList from '../components/articlelist.astro'
import CTAForm from '../components/ctaform.astro'
import Work from '../components/work.astro'
import Education from '../components/education.astro'
import Superpowers from '../components/superpowers.astro'

const { frontmatter } = Astro.props

let social = await getCollection('social')
social = social.sort((a, b) => a.data.order - b.data.order)
---

<Layout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  home={true}
>
  <div class='sm:px-8'>
    <div class='mx-auto max-w-7xl lg:px-8'>
      <div class='px-4 relative lg:px-12 sm:px-8'>
        <div class='mx-auto max-w-2xl lg:max-w-5xl'>
          <div class='mt-16 animate-fade-in-up'>
            <div class='mx-auto max-w-2xl lg:max-w-4xl'>
              <div class='flex gap-6 items-center'>
                <a href='/' aria-label='Home' class='shrink-0 h-32 w-32 block pointer-events-auto'>
                  <Image
                    src={Avatar}
                    alt='Avatar'
                    width={256}
                    height={256}
                    loading='eager'
                    class='rounded-full bg-sugarSwizzle h-32 w-32 ring-1 ring-opalGray/20 shadow-md object-cover dark:bg-blackBeauty dark:ring-opalGray/20'
                  />
                </a>
                <h1 class='text-3xl text-accent tracking-tight font-serif font-italic sm:text-4xl'>
                  {frontmatter.description}
                </h1>
              </div>
              <div
                class='text-base text-graniteGray mx-auto mt-6 max-w-2xl space-y-7 prose dark:text-opalGray lg:max-w-4xl dark:prose-invert'
              >
                <slot />
              </div>
              <div class='mt-6 flex gap-6'>
                {
                  social.map((item) => (
                    <a
                      class='group p-1 -m-1'
                      aria-label={'Follow on ' + item.data.title}
                      href={item.data.link}
                    >
                      <span
                        class:list={[
                          'h-6 w-6 text-secondary transition group-hover:text-accent',
                          item.data.icon
                        ]}
                      />
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class='[animation-delay:200ms] animate-fade-in-up'>
    <ImageCards />
  </div>

  <div class='mt-24 [animation-delay:400ms] animate-fade-in-up md:mt-28 sm:px-8'>
    <div class='mx-auto max-w-7xl lg:px-8'>
      <div class='px-4 relative lg:px-12 sm:px-8'>
        <div class='mx-auto max-w-2xl lg:max-w-5xl'>
          <div class='mx-auto gap-y-20 grid grid-cols-1 xl:grid-cols-2'>
            <div class='space-y-10 lg:pl-16 xl:pl-8'>
              <section aria-label='Call to action'>
                <CTAForm />
              </section>
              <section aria-label='Superpowers'>
                <Superpowers />
              </section>
              <section aria-label='Latest articles'>
                <ArticleList />
              </section>
            </div>
            <div class='space-y-10 lg:pl-16 xl:pl-8'>
              <section aria-label='Work history'>
                <Work />
              </section>
              <section aria-label='Education history'>
                <Education />
              </section>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
