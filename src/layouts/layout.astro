---
import Header from '../components/header.astro'
import Footer from '../components/footer.astro'
import { ClientRouter } from 'astro:transitions'
import { getCollection } from 'astro:content'
import type { ImageMetadata } from 'astro'
import { Font, getImage } from 'astro:assets'

import config from '../config.json' with { type: 'json' }

export interface Props {
  title: string
  description: string
  image?: string | ImageMetadata
  article?: boolean
  pubDate?: Date
  itemPage?: boolean
  home?: boolean
}

const {
  title,
  description,
  image = '/screenshot.png',
  article = false,
  pubDate,
  itemPage = false,
  home = false
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)

let socialImageURL = typeof image === 'string' ? image : '/screenshot.png'
if (typeof image === 'object') {
  const optimizedImage = await getImage({
    src: itemPage && image ? image : image, // Keep optimization logic
    width: 1200,
    height: 630,
    format: 'jpg'
  })
  socialImageURL = optimizedImage.src
}

const finalSocialImageURL = new URL(
  socialImageURL,
  Astro.site || 'https://astro-spotlite.netlify.app'
)

const social = await getCollection('social')

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: config.name,
  url: Astro.site,
  description: config.description
}

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: config.name,
  url: Astro.site,
  image: socialImageURL,
  sameAs: social.map((item) => item.data.link),
  jobTitle: config.title,
  worksFor: {
    '@type': 'Organization',
    name: config.organization
  }
}

let articleSchema = {}
if (article) {
  articleSchema = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description,
    image: finalSocialImageURL,
    datePublished: pubDate?.toISOString(),
    author: {
      '@type': 'Person',
      name: config.name
    }
  }
}

let itemPageSchema = {}
if (itemPage) {
  itemPageSchema = {
    '@context': 'https://schema.org',
    '@type': 'ItemPage',
    name: title,
    description: description,
    image: finalSocialImageURL
  }
}

const breadcrumbList = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: Astro.url.pathname
    .split('/')
    .filter((path) => path !== '')
    .reduce(
      (acc, path, index, array) => {
        const url = new URL('/' + array.slice(0, index + 1).join('/') + '/', Astro.site)
        acc.push({
          '@type': 'ListItem',
          position: index + 2,
          name: path.charAt(0).toUpperCase() + path.slice(1),
          item: url.href
        })
        return acc
      },
      [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: Astro.site?.href
        }
      ]
    )
}
---

<!doctype html>
<html
  lang='en'
  class:list={[
    import.meta.env.DEV && 'dev-stable-render',
    import.meta.env.DEV && 'dev-await-styles'
  ]}
>
  <head>
    <meta charset='UTF-8' />
    <meta http-equiv='x-ua-compatible' content='ie=edge' />
    <meta name='viewport' content='width=device-width,initial-scale=1' />
    <Font cssVariable='--font-noto-sans' preload />
    <Font cssVariable='--font-noto-serif' />
    <Font cssVariable='--font-noto-sans-mono' />
    <script is:inline>
      const setTheme = () => {
        if (
          localStorage.theme === 'dark' ||
          (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)
        ) {
          document.documentElement.classList.add('dark')
        } else {
          document.documentElement.classList.remove('dark')
        }
      }
      setTheme()
      document.addEventListener('astro:after-swap', setTheme)

      if (document.documentElement.classList.contains('dev-await-styles')) {
        const reveal = () => document.documentElement.classList.remove('dev-await-styles')
        window.addEventListener('load', reveal, { once: true })
        // Fallback in case a dev asset request is delayed.
        setTimeout(reveal, 2000)
      }
    </script>
    <style is:global>
      :root {
        --bg-pink: #fdf2f8;
      }
      html {
        background-color: var(--bg-pink);
        overflow-x: hidden;
      }
      html.dark {
        background-color: #000;
      }
      body {
        margin: 0;
        font-family: var(--font-noto-sans);
      }

      .font-serif {
        font-family: var(--font-noto-serif) !important;
      }

      .font-mono {
        font-family: var(--font-noto-sans-mono) !important;
      }
      @keyframes fade-in-up-custom {
        from {
          opacity: 0;
          transform: translateY(1rem);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-fade-in-up {
        animation: fade-in-up-custom 0.5s ease-out forwards;
      }

      /* Keep dev first paint stable by disabling entrance motion and transitions. */
      .dev-stable-render *,
      .dev-stable-render *::before,
      .dev-stable-render *::after {
        animation: none !important;
        transition: none !important;
      }

      .dev-stable-render .animate-fade-in-up {
        opacity: 1 !important;
        transform: none !important;
      }

      .dev-await-styles body {
        opacity: 0;
      }
    </style>
    <link rel='icon' href='/favicon.ico' sizes='any' />
    <link rel='icon' href='/favicon.svg' type='image/svg+xml' />
    <link rel='apple-touch-icon' href='/apple-touch-icon.png' />
    <link rel='manifest' href='/site.webmanifest' />
    <link rel='sitemap' href='/sitemap-index.xml' />
    <link rel='alternate' type='application/rss+xml' title='RSS' href='/rss.xml' />
    <link rel='canonical' href={canonicalURL} />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalURL} />
    <meta property='og:image' content={finalSocialImageURL} />
    <meta property='og:type' content={article ? 'article' : 'website'} />
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={finalSocialImageURL} />
    <script is:inline type='application/ld+json' set:html={JSON.stringify(websiteSchema)} />
    <script is:inline type='application/ld+json' set:html={JSON.stringify(personSchema)} />
    {
      article && (
        <script is:inline type='application/ld+json' set:html={JSON.stringify(articleSchema)} />
      )
    }
    {
      itemPage && (
        <script is:inline type='application/ld+json' set:html={JSON.stringify(itemPageSchema)} />
      )
    }
    {
      Astro.url.pathname !== '/' && (
        <script is:inline type='application/ld+json' set:html={JSON.stringify(breadcrumbList)} />
      )
    }
    {!import.meta.env.DEV && <ClientRouter />}
  </head>
  <body>
    <div class='flex pointer-events-none inset-0 justify-center fixed'>
      <div class='mx-auto flex max-w-7xl w-full pointer-events-none sm:px-8'>
        <div
          class='mx-auto bg-white w-full pointer-events-none ring-1 ring-pink-100 lg:px-8 dark:bg-zinc-900 dark:ring-pink-300/20'
        >
        </div>
      </div>
    </div>
    <div class='flex flex-col min-h-screen relative z-10'>
      <Header home={home} />
      <main class='flex-1'>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
